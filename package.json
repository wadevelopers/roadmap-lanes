{
	"name": "roadmap-lanes",
	"version": "0.1.0",
	"description": "Plugin de Obsidian: tablero de carriles de trabajo en paralelo con tiempo-como-altura y cálculo de solape.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
	},
	"keywords": ["obsidian-plugin", "roadmap", "kanban", "gantt", "carriles"],
	"author": "Martincho",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.11.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.20.0",
		"obsidian": "latest",
		"tslib": "^2.6.2",
		"typescript": "^5.4.0"
	},
	"dependencies": {
		"js-yaml": "^4.1.0"
	}
}
